# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# Build directory
build/
dist/

# Database files
*.db
*.sqlite
*.sqlite3

# Log files
*.log
logs/

# Configuration files (keep examples)
config/*.yaml
config/*.yml
config/*.json
!config/*.example.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
tmp/
temp/
.tmp/

# Coverage files
coverage.out
coverage.html

# Air (hot reload) files
.air.toml
tmp/

# Docker volumes
data/

# Environment files
.env
.env.local
.env.*.local

# Node modules (if any frontend build tools)
node_modules/

# Compiled frontend assets (keep the embedded ones)
web/dist/*
!web/dist/index.html